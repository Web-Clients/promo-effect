# ============================================
# Promo-Efect Backend - Environment Variables
# ============================================
NODE_ENV=development
PORT=3001
FRONTEND_URL=http://localhost:3000
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173,http://141.227.180.43
DATABASE_URL=postgresql://promo_effect:password@localhost:5432/promo_effect
REDIS_URL=redis://localhost:6379
JWT_SECRET=your-super-secret-jwt-key-change-in-production
JWT_EXPIRES_IN=24h
REFRESH_TOKEN_EXPIRES_IN=7d
GMAIL_CLIENT_ID=your-gmail-client-id.apps.googleusercontent.com
GMAIL_CLIENT_SECRET=your-gmail-client-secret
GMAIL_REDIRECT_URI=http://localhost:3001/api/admin/gmail/callback
GEMINI_API_KEY=your-gemini-api-key
# Email via Infobip
INFOBIP_API_KEY=your-infobip-api-key
INFOBIP_BASE_URL=xxxxx.api.infobip.com
INFOBIP_FROM_EMAIL=noreply@promo-efect.md
INFOBIP_FROM_NAME=Promo-Efect
TWILIO_ACCOUNT_SID=your-twilio-account-sid
TWILIO_AUTH_TOKEN=your-twilio-auth-token
AWS_ACCESS_KEY_ID=your-aws-access-key
AWS_SECRET_ACCESS_KEY=your-aws-secret-key
AWS_REGION=eu-west-1
SENTRY_DSN=your-sentry-dsn
LOG_LEVEL=info

# TrackGPS API Configuration
TRACKGPS_API_URL=https://api.trackgps.ro/api
TRACKGPS_USERNAME=your-trackgps-username
TRACKGPS_PASSWORD=your-trackgps-password
